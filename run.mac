# ============================================================
# run.mac
# Simple GPS test: one geantino through the cylinder
# ============================================================

# ------------------------------------------------------------
# Particle type
# ------------------------------------------------------------
/gps/particle geantino

# ------------------------------------------------------------
# Particle energy
# ------------------------------------------------------------
/gps/energy 1 GeV

# ------------------------------------------------------------
# Source position
#
# Cylinder is centered at origin.
# Cylinder length is 10 cm, so it spans z = -5 cm to +5 cm.
# Start particle upstream at z = -20 cm.
# ------------------------------------------------------------
/gps/pos/type Point
/gps/pos/centre 0 0 -20 cm

# ------------------------------------------------------------
# Direction
#
# Shoot along +z, through the center of the cylinder.
# ------------------------------------------------------------
/gps/direction 0 0 1

# ------------------------------------------------------------
# Verbosity
#
# tracking/verbose 1 prints step-by-step tracking.
# Useful for checking that the particle enters/leaves volumes.
# ------------------------------------------------------------
/tracking/verbose 1

# ------------------------------------------------------------
# Run
# ------------------------------------------------------------
/run/beamOn 1